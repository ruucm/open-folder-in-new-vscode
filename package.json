{
	"name": "open-folder-in-new-vscode",
	"publisher": "rajratnamaitry",
	"displayName": "Open folder in new vscode",
	"description": "Quickly open any folder in a new vscode window. Ideal for repositories containing monorepo projects.",
	"version": "1.1.0",
	"author": {
		"name": "rajratna maitry",
		"email": "rajratnamaitry@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/rajratnamaitry/open-folder-in-new-vscode.git"
	},
	"engines": {
		"vscode": "^1.80.0"
	},
	"icon": "open-window-icon.png",
	"keywords": [
		"open",
		"file",
		"browser",
		"display",
		"vscode"
	],
	"homepage": "https://github.com/rajratnamaitry/open-folder-in-new-vscode",
	"bugs": {
		"url": "https://github.com/rajratnamaitry/open-folder-in-new-vscode/issues"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
	],
	"main": "./extension.js",
	"contributes": {
		"commands": [
			{
				"command": "open-folder-in-new-vscode.openFolder",
				"title": "Open folder in new window"
			}
		],
		"menus": {
			"explorer/context": [
				{
					"when": "explorerResourceIsFolder",
					"command": "open-folder-in-new-vscode.openFolder"
				}
			]
		}
	},
	"scripts": {
		"lint": "eslint .",
		"pretest": "npm run lint",
		"deploy": "vsce package && vsce publish",
		"test": "vscode-test"
	},
	"devDependencies": {
		"@types/glob": "^7.2.0",
		"@types/mocha": "^9.1.1",
		"@types/node": "16.x",
		"@types/vscode": "^1.80.0",
		"@vscode/test-cli": "^0.0.11",
		"@vscode/test-electron": "^2.5.2",
		"eslint": "^8.18.0",
		"glob": "^8.0.3",
		"mocha": "^10.0.0",
		"typescript": "^4.7.4"
	}
}